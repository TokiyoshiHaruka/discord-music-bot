# Discord Developer Portal
DISCORD_TOKEN=replace-with-discord-bot-token
DISCORD_CLIENT_ID=replace-with-discord-application-id
DISCORD_GUILD_ID=

# Lavalink
LAVALINK_HOST=discord-lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=replace-with-a-long-random-password

# Optional metadata resolvers
# The bot can still use public preview metadata and YouTube fallback without these.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
APPLE_MUSIC_MEDIA_API_TOKEN=

# Playback
DEFAULT_VOLUME=80
AUDIO_NORMALIZATION_PRE_GAIN=1.3
AUDIO_NORMALIZATION_MAX_AMPLITUDE=0.65
LOG_LEVEL=info

# 1Panel compose defaults
CONTAINER_NAME=1Panel-discord-music-bot
CPUS=0
MEMORY_LIMIT=0
